
# Do not force new Ghostty windows to open maximized/fullscreen.
# AeroSpace should control window size/tiling.
# fullscreen = true
# macos-non-native-fullscreen = visible-menu
# maximize = true

# making things bigger
font-size = 18
# setting fontface for terminal
font-family = "JetBrains Mono"

# theme for ghostty
theme = "Gruvbox Dark Hard"

# transparent background
background-opacity = 0.6
background-blur-radius = 20

# cosmetic: nicer icon on macos
macos-icon = "blueprint"
# cosmetic: hiding mouse when editing
mouse-hide-while-typing = true
